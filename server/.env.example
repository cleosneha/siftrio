# =====================================
# App
# =====================================

PROJECT_NAME=siftrio
PROJECT_VERSION=0.1.0

# =====================================
# URLs
# =====================================

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# =====================================
# Database (Supabase)
# =====================================

# Production (Supabase):
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Local development:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_project_memory

# =====================================
# Auth
# =====================================

JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# =====================================
# Google OAuth
# =====================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =====================================
# Atlassian (Jira)
# =====================================

ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=

# =====================================
# Mistral AI
# =====================================

MISTRAL_API_KEY=
MISTRAL_LLM_MODEL=mistral-small-latest
MISTRAL_EMBED_MODEL=mistral-embed

# =====================================
# Fireflies (Transcription)
# =====================================

FIREFLIES_API_KEY=
FIREFLIES_WEBHOOK_SECRET=

# =====================================
# CORS
# =====================================

# Production: comma-separated list of allowed origins
# CORS_ORIGINS=https://your-app.vercel.app

# Local development (defaults applied if not set):
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
