# =====================================
# App
# =====================================

PROJECT_NAME=siftrio
PROJECT_VERSION=0.1.0

# =====================================
# URLs
# =====================================

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# =====================================
# Database
# =====================================

# Full connection URL (takes precedence over POSTGRES_* vars):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_project_memory

# Or configure individually (used when DATABASE_URL is not set):
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_SERVER=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=ai_project_memory

# =====================================
# Auth
# =====================================

JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# =====================================
# Cookies
# =====================================

# Set to True in production (HTTPS only)
COOKIE_SECURE=False
COOKIE_SAMESITE=lax

# =====================================
# Google OAuth
# =====================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =====================================
# Atlassian (Jira)
# =====================================

ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=

# =====================================
# Mistral AI
# =====================================

MISTRAL_API_KEY=
MISTRAL_LLM_MODEL=mistral-small-latest
MISTRAL_EMBED_MODEL=mistral-embed

# =====================================
# Transcript Chunking
# =====================================

CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# =====================================
# Fireflies (Transcription)
# =====================================

FIREFLIES_API_KEY=
FIREFLIES_WEBHOOK_SECRET=

# =====================================
# SMTP (Email)
# =====================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@siftrio.com
SMTP_FROM_NAME=Siftrio

# =====================================
# Cron Jobs
# =====================================

# Bearer token for authenticating external cron calls
CRON_SECRET=

# =====================================
# CORS
# =====================================

# Comma-separated list of allowed origins
# Production: CORS_ORIGINS=https://your-app.vercel.app
# Local development defaults to localhost:3000 and :5173 if not set
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173
